{
  "name": "@us4/den",
  "version": "0.0.6",
  "description": "TypeScript SDK for the Den sandbox API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/us/den",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/us/den#readme",
  "bugs": {
    "url": "https://github.com/us/den/issues"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "den",
    "sandbox",
    "sdk",
    "docker",
    "ai",
    "code-execution"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/bun": "latest"
  }
}
